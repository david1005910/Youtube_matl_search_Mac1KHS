{
  "manifest_version": 3,
  "name": "Grok Bridge - YouTube Tool Connector",
  "version": "1.0.0",
  "description": "YouTube 소재 발굴 도구와 grok.com을 연결하여 AI 영상/이미지를 자동 생성합니다.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "http://localhost:8765/*",
    "http://localhost/*",
    "https://grok.com/*",
    "https://*.grok.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:8765/*", "http://localhost/*"],
      "js": ["content_app.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*", "https://*.grok.com/*"],
      "js": ["content_grok.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grok Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
