{
  "_comment": "Wan2.1 Image-to-Video Workflow for ComfyUI (RTX 3060 12GB compatible)",
  "_usage": "Upload image first via /api/proxy/comfyui/upload/image, then use returned filename in node 4",
  "prompt": {
    "1": {
      "class_type": "DownloadAndLoadWanModel",
      "inputs": {
        "model": "Wan2.1-I2V-14B-480P-bf16",
        "precision": "bf16"
      }
    },
    "2": {
      "class_type": "DownloadAndLoadWanTextEncoder",
      "inputs": {
        "model": "umt5-xxl-enc-fp8_e4m3fn",
        "precision": "fp8_e4m3fn"
      }
    },
    "3": {
      "class_type": "DownloadAndLoadWanVAE",
      "inputs": {}
    },
    "4": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "input_image.png"
      }
    },
    "5": {
      "class_type": "DownloadAndLoadCLIPVisionModel",
      "inputs": {
        "model": "google--siglip-so400m-patch14-384"
      }
    },
    "6": {
      "class_type": "WanClipVisionEncode",
      "inputs": {
        "clip_vision": ["5", 0],
        "image": ["4", 0]
      }
    },
    "7": {
      "class_type": "WanTextEncode",
      "inputs": {
        "text_encoder": ["2", 0],
        "prompt": "The camera slowly pans across the scene, gentle motion",
        "force_offload": true
      }
    },
    "8": {
      "class_type": "WanImageToVideo",
      "inputs": {
        "model": ["1", 0],
        "positive": ["7", 0],
        "negative": ["7", 1],
        "image_embeds": ["6", 0],
        "image": ["4", 0],
        "width": 832,
        "height": 480,
        "num_frames": 49,
        "seed": 12345,
        "steps": 20,
        "cfg": 5.0,
        "shift": 5.0,
        "scheduler": "DPM++ 2M SDE"
      }
    },
    "9": {
      "class_type": "WanDecode",
      "inputs": {
        "vae": ["3", 0],
        "latent": ["8", 0]
      }
    },
    "10": {
      "class_type": "VHS_VideoCombine",
      "inputs": {
        "images": ["9", 0],
        "frame_rate": 16,
        "loop_count": 0,
        "filename_prefix": "wan21_i2v",
        "format": "video/h264-mp4",
        "pingpong": false,
        "save_output": true
      }
    }
  }
}
